#twitter API
CONSUMER_KEY=XXXXXXXXXXXXXXXXXXXXXXXXX
CONSUMER_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ACCESS_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TOKEN_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

#use twitter id
TWITTER_ID=XXXXXXX

#admin twitter account id to get DM
ADMIN_RECIPIENT_ID=XXXXXXXXX

# ===== mixi2 Application API (hometamon_mixi2.py) =====
# 接続・認証（開発者コンソールで発行・要記入）
CLIENT_ID=XXXXXXXXXXXXXXXX
CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXX
TOKEN_URL=https://example.mixi.social/oauth/token
API_ADDRESS=api.mixi.social:443

# 識別子（要記入）: 巡回コミュニティ / bot自身 / レポートDM送信先
COMMUNITY_ID=XXXXXXXX
BOT_USER_ID=XXXXXXXX
ADMIN_USER_ID=XXXXXXXX

# 褒めスタンプID（mixi2_probe で選定して記入）
PRAISE_STAMP_ID=XXXXXXXX

# 疎通確認の安全トグル: "1" で書き込みRPCを実行せずログのみ（本番は 0）
MIXI2_DRY_RUN=1

# 注) MAX_REPLIES_PER_RUN / POLL_MIN_SLEEP / POLL_MAX_SLEEP / MAX_POST_LEN は
#     秘密ではなくチューニング値。既定値は hometamon_mixi2.py 側にあり、変える時だけ
#     docker-compose の environment 等で環境変数指定する（.env には置かない）。